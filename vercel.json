{
  "redirects": [
    { "source": "/:path*", "destination": "https://shrimply.app/:path*", "permanent": true, "has": [{ "type": "host", "value": "www.shrimply.app" }] }
  ],
  "rewrites": [
    { "source": "/google7d69f80b431c47bc.html", "destination": "/google7d69f80b431c47bc.html" },
    { "source": "/sitemap.xml", "destination": "/sitemap.xml" },
    { "source": "/robots.txt", "destination": "/robots.txt" },
    { "source": "/blog", "destination": "/blog/index.html" },
    { "source": "/blog/:slug", "destination": "/blog/:slug.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    }
  ]
}