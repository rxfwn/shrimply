    "faq": {
      "section_label": "frequently asked questions",
      "section_title": "got questions?",
      "items": [
        {
          "q": "What exactly is Shrimply?",
          "a": "Shrimply is a web app that helps you plan your weekly meals and automatically generate your shopping list. You create or import recipes, place them on a calendar, and your shopping list fills itself."
        },
        {
          "q": "Can I use Shrimply on my phone?",
          "a": "Yes! Shrimply is a PWA — you can install it on your home screen like a real app. Your shopping list syncs in real time between your PC and your phone."
        },
        {
          "q": "Can I share my recipes?",
          "a": "Absolutely. You can make your recipes public and share them with the whole community. Others can rate them and import them in one click."
        },
        {
          "q": "How does the automatic shopping list work?",
          "a": "When you place recipes on your calendar, Shrimply collects all the ingredients and groups them automatically by category. No more counting or writing things down by hand."
        },
        {
          "q": "Can I cancel my subscription at any time?",
          "a": "Yes, no commitment or fees. You can cancel at any time from your profile. Your recipes remain accessible in Free mode."
        },
        {
          "q": "Is it really worth €4.99/month?",
          "a": "A single delivery order often costs €20-30. Shrimply helps you plan, avoid waste and stop ordering out of laziness. Most users save €50 to €100 per month."
        }
      ]
    },
